# Database Configuration
DATABASE_URL=postgresql+asyncpg://aifactory:aifactory123@localhost:5432/aifactory

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Anthropic API Key (via OpenAI-compatible endpoint)
ANTHROPIC_API_KEY=your-api-key-here

# LLM Configuration (OpenAI-compatible endpoint, supports custom deployment)
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: GitHub Configuration (for repository creation)
GITHUB_TOKEN=your-github-token-here

# Optional: Deployment Configuration
VERCEL_TOKEN=your-vercel-token-here
NETLIFY_TOKEN=your-netlify-token-here

# Optional: Logging
LOG_LEVEL=INFO

# =============================================================
# Feishu (Lark) Notification — choose ONE of the two modes
# =============================================================
#
# 接入指南：
#   1. 在飞书群组中添加「自定义机器人」
#   2. 复制 Webhook 地址，填写到 FEISHU_WEBHOOK_URL
#   3. （可选）开启安全校验后，填写签名密钥到 FEISHU_SIGN_SECRET
#   4. 重启服务后，访问 http://localhost:3000/settings 发送测试消息验证
#   或直接使用 CLI：python3 scripts/notify_test.py --all
#
# -- Mode 1: Custom Bot Webhook (推荐 MVP 使用) --
# 在飞书群里添加「自定义机器人」，复制 Webhook 地址填到这里
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# （可选）开启安全校验后，填写签名密钥
# FEISHU_SIGN_SECRET=your-sign-secret-here

# -- Mode 2: App Bot (企业应用，支持主动推送到任意会话) --
# 需要在飞书开放平台创建应用并开通「发送消息」权限
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxx...xxxx
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

